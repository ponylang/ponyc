diff --git i/lld/ELF/Driver.cpp w/lld/ELF/Driver.cpp
index ee5a10171..ce31c39fa 100644
--- i/lld/ELF/Driver.cpp
+++ w/lld/ELF/Driver.cpp
@@ -149,7 +149,10 @@ static std::tuple<ELFKind, uint16_t, uint8_t> parseEmulation(Ctx &ctx,
                                                              StringRef emul) {
   uint8_t osabi = 0;
   StringRef s = emul;
-  if (s.ends_with("_fbsd")) {
+  if (s.ends_with("_obsd")) {
+    s = s.drop_back(5);
+    osabi = ELFOSABI_OPENBSD;
+  } else if (s.ends_with("_fbsd")) {
     s = s.drop_back(5);
