   }
diff --git i/lld/ELF/DriverUtils.cpp w/lld/ELF/DriverUtils.cpp
index 6d027c529..fb5ebcf9d 100644
--- i/lld/ELF/DriverUtils.cpp
+++ w/lld/ELF/DriverUtils.cpp
@@ -236,15 +236,58 @@ std::optional<std::string> elf::findFromSearchPaths(Ctx &ctx, StringRef path) {
   return std::nullopt;
 }
 
+namespace {
+// OpenBSD ports its shared libraries as libNAME.so.MAJOR.MINOR with no
+// libNAME.so symlink. Search for the highest-versioned match. Modeled on
+// the OpenBSD lld fork's same-named helper, which is in turn kept in sync
+// with clang/lib/Driver/Driver.cpp.
+static std::optional<std::string> findMajMinShlib(Ctx &ctx, StringRef dir,
+                                                  const Twine &libNameSo) {
+  llvm::SmallString<128> scratch;
+  StringRef libName = (libNameSo + ".").toStringRef(scratch);
+  int maxMaj = -1, maxMin = -1;
+  std::error_code ec;
+  for (llvm::sys::fs::directory_iterator li(dir, ec), le; li != le;
+       li = li.increment(ec)) {
+    StringRef fileName = llvm::sys::path::filename(StringRef(li->path()));
+    if (!fileName.starts_with(libName))
+      continue;
+    std::pair<StringRef, StringRef> majMin =
+        fileName.substr(libName.size()).split('.');
+    int maj, min;
+    if (majMin.first.getAsInteger(10, maj) || maj < 0)
+      continue;
+    if (majMin.second.getAsInteger(10, min) || min < 0)
+      continue;
+    if (maj > maxMaj)
+      maxMaj = maj, maxMin = min;
+    if (maxMaj == maj && min > maxMin)
+      maxMin = min;
+  }
+  if (maxMaj >= 0)
+    return findFile(ctx, dir, libName + Twine(maxMaj) + "." + Twine(maxMin));
+  return std::nullopt;
+}
+} // namespace
+
 // This is for -l<basename>. We'll look for lib<basename>.so or lib<basename>.a from
 // search paths.
 std::optional<std::string> elf::searchLibraryBaseName(Ctx &ctx,
                                                       StringRef name) {
   for (StringRef dir : ctx.arg.searchPaths) {
-    if (!ctx.arg.isStatic)
+    if (!ctx.arg.isStatic) {
       if (std::optional<std::string> s =
               findFile(ctx, dir, "lib" + name + ".so"))
         return s;
+      // OpenBSD-only: scan for libNAME.so.MAJOR.MINOR. Gated on the
+      // OpenBSD OSABI so other ELF targets don't pay the per-link
+      // directory-iteration cost and don't change their resolution
+      // behavior. Set by -m elf_x86_64_obsd via parseEmulation.
+      if (ctx.arg.osabi == llvm::ELF::ELFOSABI_OPENBSD)
+        if (std::optional<std::string> s =
+                findMajMinShlib(ctx, dir, "lib" + name + ".so"))
+          return s;
+    }
     if (std::optional<std::string> s = findFile(ctx, dir, "lib" + name + ".a"))
       return s;
   }
