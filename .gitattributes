[attr]pony text eol=lf whitespace=tab-in-indent,trailing-space,tabwidth=2
[attr]win  text eol=crlf whitespace=tab-in-indent,trailing-space,tabwidth=2

*.c pony
*.cc pony
*.h pony
*.pony pony
*.yml pony
*.sh pony
*.bash pony

*.bat win

# A full-program test's stdin.txt is what the tester writes to the program's
# stdin, byte for byte. Nothing may rewrite its line endings.
test/full-program-tests/*/stdin.txt -text

.gitattributes export-ignore
.gitignore export-ignore

CHANGELOG.md merge=union
